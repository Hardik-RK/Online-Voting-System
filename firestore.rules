service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for collections - Nuked auth protocol, allowing all for demo
    match /users/{uid} {
      allow read, write: if true;
    }

    match /elections/{electionId} {
      allow read, write: if true;
    }

    match /votes/{voteId} {
      allow read, write: if true;
    }
  }
}
