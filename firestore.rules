service cloud.firestore {
  match /databases/{database}/documents {
    // DEMO ONLY: open rules for local development. Replace with auth-scoped rules before any production deployment.
    match /users/{uid} {
      allow read, write: if true;
    }

    match /elections/{electionId} {
      allow read, write: if true;
    }

    match /votes/{voteId} {
      allow read, write: if true;
    }
  }
}
